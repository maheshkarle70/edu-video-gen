# ─────────────────────────────────────────────────────────────────
#  Edu Video Gen — Environment Variables
#  Copy this file: cp .env.example .env
#  Then fill in your keys and run: node server/index.js
# ─────────────────────────────────────────────────────────────────

# ── Anthropic / Claude ────────────────────────────────────────────
# Generates the educational script — required
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── ElevenLabs (AI voiceover) ─────────────────────────────────────
# Converts narration to speech — optional (video renders silent without it)
# Get key: https://elevenlabs.io → Profile → API Keys
# Free tier: 10,000 chars/month (~20 videos)
ELEVENLABS_API_KEY=sk_...

# ── ElevenLabs Voice ──────────────────────────────────────────────
# Choose from the voice cards in the UI, or paste a voice ID here
# pNInz6obpgDQGcFmaJgB  → Adam      (deep, authoritative — best for facts)
# ErXwobaYiN019PkySvjV  → Antoni    (warm, conversational)
# TxGEqnHWrfWFTfGW9XjX  → Josh      (confident, clear)
# yoZ06aMxZJJ28mfd3POQ  → Sam       (calm, measured)
# onwK4e9ZLuTAKqWW03F9  → Daniel    (British, professional)
# VR6AewLTigWG4xSOukaG  → Arnold    (strong, powerful)
# MF3mGyEYCl7XYWbV9V6O  → Elli      (friendly female)
# jBpfuIE2acCO8z3wKNLl  → Gigi      (energetic female)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Video settings ────────────────────────────────────────────────
# portrait = 1080x1920 (YouTube Shorts / Instagram Reels)
# landscape = 1920x1080 (Standard YouTube)
VIDEO_FORMAT=portrait

# Frames per second (24 or 30)
VIDEO_FPS=30

# ── Output ────────────────────────────────────────────────────────
OUTPUT_DIR=./output
PORT=4000
