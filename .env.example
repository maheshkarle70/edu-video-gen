# ─────────────────────────────────────────────────────────────────
#  Edu Video Gen — Environment Variables
#  Copy this file to .env and fill in your keys
#  Then run: npm start
# ─────────────────────────────────────────────────────────────────

# ── Anthropic / Claude ────────────────────────────────────────────
# Generates the educational script, scene breakdown, quiz questions
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── ElevenLabs (TTS voiceover) ────────────────────────────────────
# Converts each scene's narration to speech audio
# Get key: https://elevenlabs.io → Profile → API Keys
# Free tier: 10,000 chars/month
ELEVENLABS_API_KEY=sk_...

# ── ElevenLabs Voice ID ───────────────────────────────────────────
# Choose a voice that suits your educational style:
#   pNInz6obpgDQGcFmaJgB  → Adam      (deep, authoritative — great for explainers)
#   ErXwobaYiN019PkySvjV  → Antoni    (warm, friendly — good for younger audience)
#   TxGEqnHWrfWFTfGW9XjX  → Josh      (confident, clear)
#   yoZ06aMxZJJ28mfd3POQ  → Sam       (calm, measured — good for science topics)
#   onwK4e9ZLuTAKqWW03F9  → Daniel    (British, professional)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Video Settings ────────────────────────────────────────────────
# Resolution: 1080x1920 (portrait/Shorts) or 1920x1080 (landscape/YouTube)
VIDEO_FORMAT=portrait

# Frames per second (30 recommended)
VIDEO_FPS=30

# Output folder for rendered MP4s
OUTPUT_DIR=./output

# ── Server ────────────────────────────────────────────────────────
PORT=4000
